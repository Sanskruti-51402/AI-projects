# --- A* Algorithm functions ---
def heuristic(a, b):
return abs(a[0] - b[0]) + abs(a[1] - b[1])
def astar(grid, start, goal):
open_list = []
heapq.heappush(open_list, (0, start))
came_from = {}
g_score = {start: 0}
while open_list:
current = heapq.heappop(open_list)[1]
if current == goal:
path = []
while current in came_from:
path.append(current)
current = came_from[current]
path.append(start)
return path[::-1]
for dx, dy in [(0,1),(1,0),(-1,0),(0,
-1)]:
neighbor = (current[0]+dx, current[1]+dy)
if 0 <= neighbor[0] < len(grid) and 0 <= neighbor[1] < len(grid[0]):
if grid[neighbor[0]][neighbor[1]] == 1:
continue
temp_g = g_score[current] + 1
if neighbor not in g_score or temp_g < g_score[neighbor]:
g_score[neighbor] = temp_g
f_score = temp_g + heuristic(neighbor, goal)
heapq.heappush(open_list, (f_score, neighbor))
came_from[neighbor] = current
return None
# --- Minimax Algorithm ---
def minimax(depth, isMax, values):
if depth == 1:
return values
if isMax:
return max(minimax(depth+1, False, v) for v in values)
else:
return min(minimax(depth+1, True, v) for v in values)
# --- Environment Grid ---
hospital_map = [
[0,0,0],
[0,1,0],
[0,0,0]
]
start = (0,0)
goal = (2,2)
# --- Widgets ---
area_dropdown = Dropdown(
options=['North Zone'
,
'South Zone'
,
'Central Zone'],
description='Select Area:'
)
density_dropdown = Dropdown(
options=['Low'
,
'Medium'
,
'High'],
description='Traffic Density:'
)
process_button = Button(description="Process Emergency"
,
button_style='success')
output = Output()
def on_button_clicked(b):
output.clear_output()
with output:
area = area_dropdown.value
density = density_dropdown.value
# A* path planning
path = astar(hospital_map, start, goal)
# Map traffic density to values
if density == "High":
traffic_values = [80, 60, 40]
elif density == "Medium":
traffic_values = [50, 30, 20]
else:
traffic_values = [20, 10, 5]
best_signal = minimax(0, True, traffic_values)
print(f"Emergency Area Selected: {area}")
print(f"Traffic Density: {density}")
print(f"Optimal Route: {path}")
print(f"Recommended Signal Priority Score: {best_signal}")
process_button.on_click(on_button_clicked)
# --- Layout ---
ui = VBox([area_dropdown, density_dropdown, process_button,
output])
display(ui)
